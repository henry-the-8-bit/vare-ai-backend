modules = ["nodejs-24", "postgresql-16"]

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/mockup-sandbox"

  [deployment]
  router = "application"
  deploymentTarget = "autoscale"
  build = ["pnpm", "--filter", "@workspace/api-server", "run", "build"]
  run = ["node", "artifacts/api-server/dist/index.cjs"]

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
  runButton = "Project"

  [agent]
  stack = "PNPM_WORKSPACE"
expertMode = true

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000

  [userenv]

  [userenv.shared]
  ENCRYPTION_KEY = "81bed73021e51cffaf30e61840a8c6aa9cfc3753c1c39e8482ec141c4c853e69"
  VARE_API_SECRET = "ccba15ddcaef0d1d11b33d755d9f152abaa0e702f6b9b1d718aee08e594df62f"

  [nix]
  channel = "stable-25_05"
  